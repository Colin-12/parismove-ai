# ==========================================
# ParisMove AI — Variables d'environnement
# ==========================================
# Copie ce fichier en `.env` à la racine et remplis les valeurs.
# NE COMMIT JAMAIS le fichier .env (il est dans .gitignore).

# ------------------------------------------
# PRIM Île-de-France Mobilités
# ------------------------------------------
# Inscription : https://prim.iledefrance-mobilites.fr/
# Créer une clé : Compte > API Key
PRIM_API_KEY=your_prim_key_here

# ------------------------------------------
# AQICN (qualité de l'air)
# ------------------------------------------
# Token gratuit : https://aqicn.org/data-platform/token/
AQICN_TOKEN=your_aqicn_token_here

# ------------------------------------------
# Supabase (base de données PostgreSQL + PostGIS)
# ------------------------------------------
# Crée un projet : https://supabase.com
# Récupère l'URL et la clé dans Settings > API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here
DATABASE_URL=postgresql://postgres:[password]@db.xxxxx.supabase.co:5432/postgres

# ------------------------------------------
# Groq (LLM pour le coach RAG)
# ------------------------------------------
# Clé gratuite : https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ------------------------------------------
# Open-Meteo (aucune clé nécessaire)
# ------------------------------------------
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# ------------------------------------------
# Environnement
# ------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
